.DS_Store

# Node / JS
**/node_modules/
**/.pnp
**/.pnp.*
**/.yarn/*
!**/.yarn/patches
!**/.yarn/plugins
!**/.yarn/releases
!**/.yarn/sdks
!**/.yarn/versions
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/.pnpm-debug.log*

# Env / secrets (never commit)
**/.env
**/.env.*
**/*.pem
**/firebase-service-account.json

# Cursor / Claude local state
.cursor/
.claude/settings.local.json

# Next.js
**/.next/
**/out/
**/next-env.d.ts
**/*.tsbuildinfo

# Mobile - iOS
**/ios/build/
**/ios/DerivedData/
**/ios/xcuserdata/
**/*.xcuserstate
**/*.ipa
**/*.dSYM
**/.xcode.env.local
**/Pods/

# Mobile - Android
**/.gradle/
**/android/build/
**/android/app/build/
**/android/.cxx/
**/android/local.properties
**/*.keystore
!**/debug.keystore
**/*.hprof

# React Native bundles
**/*.jsbundle

# Keep Firebase client configs tracked (needed for app to run)
!**/google-services.json
!**/GoogleService-Info.plist


