# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
$RNFirebaseAsStaticFramework = true
prepare_react_native_project!

target 'BromoMobile' do
  # FirebaseAuth (Swift) exposes FirebaseAuth-Swift.h only under a real framework layout.
  # That makes every pod a static framework, which then imports non-modular React headers;
  # CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES fixes that in post_install.
  use_frameworks! :linkage => :static

  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  pod 'GoogleMaps'

  # FirebaseAuth is Swift and needs module maps from its Obj-C dependencies.
  # Apply modular_headers only to those specific pods — NOT globally.
  pod 'GoogleUtilities', :modular_headers => true
  pod 'FirebaseAppCheckInterop', :modular_headers => true
  pod 'FirebaseAuthInterop', :modular_headers => true
  pod 'RecaptchaInterop', :modular_headers => true

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
    )

    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |cfg|
        s = cfg.build_settings
        s['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'

        s['COMPILER_INDEX_STORE_ENABLE'] = 'NO'
        s['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
        if cfg.name == 'Debug'
          s['ONLY_ACTIVE_ARCH'] = 'YES'
          s['SWIFT_OPTIMIZATION_LEVEL'] = '-Onone'
          s['GCC_OPTIMIZATION_LEVEL'] = '0'
          s['DEBUG_INFORMATION_FORMAT'] = 'dwarf'
        end
      end
    end
  end
end
