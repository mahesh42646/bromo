    "ios:device": "react-native run-ios --device \"Mahesh’s iPhone\"",
    "lint": "eslint .",
    "metro:sync-ip": "node scripts/sync-metro-host.cjs",
    "ios:device:sync": "npm run metro:sync-ip && npm run ios:device",
